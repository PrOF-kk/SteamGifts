<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground">

    <ImageView
        android:id="@+id/game_image"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/giveaway_list_item_placeholder"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="184:69"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/game_name"
        style="@style/NormalText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingVertical="8dp"
        android:paddingLeft="8dp"
        android:singleLine="true"
        app:layout_constraintLeft_toRightOf="@id/game_image"
        app:layout_constraintRight_toLeftOf="@id/remove_game"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Game Name" />


    <com.mikepenz.iconics.view.IconicsButton
        android:id="@+id/remove_game"
        style="@style/MediumButton"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:text="{faw-times}"
        android:visibility="gone"
        app:emojiCompatEnabled="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="x"
        tools:visibility="visible" />
</androidx.constraintlayout.widget.ConstraintLayout>